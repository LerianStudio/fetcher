# WORKER
ENV_NAME=development

# APP
VERSION=v1.0.0
APP_ENC_KEY=CHANGE_ME_set_encryption_key
APP_ENC_KEY_VERSION=1

# RABBITMQ
RABBITMQ_URI=amqp
RABBITMQ_HOST=fetcher-rabbitmq
RABBITMQ_PORT_AMQP=3007
RABBITMQ_PORT_HOST=3008
RABBITMQ_DEFAULT_USER=plugin
RABBITMQ_DEFAULT_PASS=CHANGE_ME_set_secure_password
RABBITMQ_HEALTH_CHECK_URL=http://${RABBITMQ_HOST}:${RABBITMQ_PORT_HOST}
RABBITMQ_NUMBERS_OF_WORKERS=5
RABBITMQ_FETCHER_WORK_QUEUE=fetcher.extract-external-data.queue
RABBITMQ_JOB_EVENTS_EXCHANGE=fetcher.job.events

# SEAWEEDFS CONFIGS
SEAWEEDFS_HOST=fetcher-seaweedfs-filer
SEAWEEDFS_FILER_PORT=8889
SEAWEEDFS_TTL=6M

# MONGO DB
#MONGO_URI=mongo+srv
MONGO_URI=mongodb
MONGO_HOST=fetcher-mongodb
MONGO_NAME=fetcher-db
MONGO_USER=plugin
MONGO_PASSWORD=CHANGE_ME_set_secure_password
MONGO_PORT=5709
MONGO_MAX_POOL_SIZE=1000

# LOG LEVEL
LOG_LEVEL=debug

# OPEN TELEMETRY
OTEL_RESOURCE_SERVICE_NAME=fetcher-worker
OTEL_LIBRARY_NAME=github.com/LerianStudio/fetcher
OTEL_RESOURCE_SERVICE_VERSION=${VERSION}
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=${ENV_NAME}
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT=midaz-otel-lgtm:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}
ENABLE_TELEMETRY=false

# LICENSE
LICENSE_KEY=your-plugin-license-key
ORGANIZATION_IDS=your-organization-id1,your-organization-id2

# SEAWEEDFS ENCRYPTION KEYS
CRYPTO_ENCRYPT_SECRET_KEY_SEAWEEDFS=your_encrypt_secret_key_here
CRYPTO_HASH_SECRET_KEY_SEAWEEDFS=your_hash_secret_key_here

# CRM PLUGIN ENCRYPTION KEYS
CRYPTO_ENCRYPT_SECRET_KEY_PLUGIN_CRM=your_crm_encrypt_secret_key_here
CRYPTO_HASH_SECRET_KEY_PLUGIN_CRM=your_crm_hash_secret_key_here

# REDIS
REDIS_HOST=fetcher-valkey
REDIS_PORT=5707
REDIS_PASSWORD=CHANGE_ME_set_secure_password
REDIS_DB=0
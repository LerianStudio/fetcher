# WORKER
ENV_NAME=development

# APP
VERSION=v1.0.0
APP_ENC_KEY=CHANGE_ME_set_encryption_key
APP_ENC_KEY_VERSION=1

# RABBITMQ
RABBITMQ_URI=amqp
RABBITMQ_HOST=fetcher-rabbitmq
RABBITMQ_PORT_AMQP=3007
RABBITMQ_PORT_HOST=3008
RABBITMQ_DEFAULT_USER=plugin
RABBITMQ_DEFAULT_PASS=CHANGE_ME_set_secure_password
RABBITMQ_HEALTH_CHECK_URL=http://${RABBITMQ_HOST}:${RABBITMQ_PORT_HOST}
RABBITMQ_NUMBERS_OF_WORKERS=5
RABBITMQ_FETCHER_WORK_QUEUE=fetcher.extract-external-data.queue
RABBITMQ_JOB_EVENTS_EXCHANGE=fetcher.job.events
#RABBITMQ_TLS=false

# Object Storage — S3-compatible (AWS S3, MinIO, SeaweedFS S3 API)
OBJECT_STORAGE_ENDPOINT=http://fetcher-seaweedfs:8333
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=fetcher-storage
OBJECT_STORAGE_KEY_PREFIX=
OBJECT_STORAGE_ACCESS_KEY_ID=any
OBJECT_STORAGE_SECRET_KEY=any
OBJECT_STORAGE_USE_PATH_STYLE=true

# MONGO DB
#MONGO_URI=mongo+srv
MONGO_URI=mongodb
MONGO_HOST=fetcher-mongodb
MONGO_NAME=fetcher-db
MONGO_USER=plugin
MONGO_PASSWORD=CHANGE_ME_set_secure_password
MONGO_PORT=5709
MONGO_PARAMETERS=
MONGO_MAX_POOL_SIZE=1000
# Base64-encoded PEM CA certificate for MongoDB TLS (optional)
#MONGO_TLS_CA_CERT=

# LOG LEVEL
LOG_LEVEL=debug

# OPEN TELEMETRY
ENABLE_TELEMETRY=false
OTEL_RESOURCE_SERVICE_NAME=fetcher-worker
OTEL_LIBRARY_NAME=github.com/LerianStudio/fetcher
OTEL_RESOURCE_SERVICE_VERSION=${VERSION}
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=${ENV_NAME}
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT=midaz-otel-lgtm:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}
OTEL_INSECURE_EXPORTER=false

# LICENSE
LICENSE_KEY=your-plugin-license-key
ORGANIZATION_IDS=your-organization-id1,your-organization-id2

# CRM PLUGIN ENCRYPTION KEYS
CRYPTO_ENCRYPT_SECRET_KEY_PLUGIN_CRM=your_crm_encrypt_secret_key_here
CRYPTO_HASH_SECRET_KEY_PLUGIN_CRM=your_crm_hash_secret_key_here

# MULTI-TENANT
MULTI_TENANT_ENABLED=false
#MULTI_TENANT_URL=http://tenant-manager:8080
#MULTI_TENANT_REDIS_HOST=redis
#MULTI_TENANT_REDIS_PORT=6379
#MULTI_TENANT_REDIS_PASSWORD=
#MULTI_TENANT_REDIS_TLS=false
#MULTI_TENANT_REDIS_CA_CERT=  # Base64-encoded PEM (optional, used when MULTI_TENANT_REDIS_TLS=true)
#MULTI_TENANT_MAX_TENANT_POOLS=100
#MULTI_TENANT_IDLE_TIMEOUT_SEC=300
#MULTI_TENANT_CIRCUIT_BREAKER_THRESHOLD=5
#MULTI_TENANT_CIRCUIT_BREAKER_TIMEOUT_SEC=30
#MULTI_TENANT_SERVICE_API_KEY=
# Per-service tenant-manager API keys (optional). Scheme:
#   MULTI_TENANT_SERVICE_API_KEY_<SERVICE>  where <SERVICE> = the service name, hyphens->underscores, upper-cased.
# When set, the resolver authenticates that service's tenant-config lookups with the matching key;
# falls back to MULTI_TENANT_SERVICE_API_KEY when a per-service key is absent.
# Adding a new service is env-only (no code change). Two env vars normalizing to the same token fail fast at startup.
#MULTI_TENANT_SERVICE_API_KEY_LEDGER=
#MULTI_TENANT_SERVICE_API_KEY_PLUGIN_CRM=
#MULTI_TENANT_CACHE_TTL_SEC=120
#MULTI_TENANT_TIMEOUT=30
#MULTI_TENANT_ALLOW_INSECURE_HTTP=false
#RABBITMQ_MULTI_TENANT_SYNC_INTERVAL=30
#RABBITMQ_MULTI_TENANT_DISCOVERY_TIMEOUT=500

# /readyz configuration (Gate 2 of ring:dev-readyz)
# DEPLOYMENT_MODE controls the deployment-mode tag emitted by /readyz and
# drives the SaaS-specific TLS enforcement added in Gate 4.
# Allowed values: saas | byoc | local  (default: local)
DEPLOYMENT_MODE=local
# HEALTH_PORT is the port the worker exposes /health, /readyz, /readyz/tenant/:id
# and /metrics on. Separate from RabbitMQ/Mongo ports because the worker has
# no primary HTTP server.
HEALTH_PORT=4007
# READYZ_DRAIN_DELAY_SEC is the graceful-drain window applied after SIGTERM —
# the process continues serving /readyz (as unhealthy) for this many seconds
# before connections are torn down, giving Kubernetes time to remove the pod
# from Service endpoints. Minimum 1s. Default 12s.
READYZ_DRAIN_DELAY_SEC=12

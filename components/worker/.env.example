# WORKER
ENV_NAME=development

# APP
VERSION=v1.0.0
APP_ENC_KEY=CHANGE_ME_set_encryption_key
APP_ENC_KEY_VERSION=1

# RABBITMQ
RABBITMQ_URI=amqp
RABBITMQ_HOST=fetcher-rabbitmq
RABBITMQ_PORT_AMQP=3007
RABBITMQ_PORT_HOST=3008
RABBITMQ_DEFAULT_USER=plugin
RABBITMQ_DEFAULT_PASS=CHANGE_ME_set_secure_password
RABBITMQ_HEALTH_CHECK_URL=http://${RABBITMQ_HOST}:${RABBITMQ_PORT_HOST}
RABBITMQ_NUMBERS_OF_WORKERS=5
RABBITMQ_FETCHER_WORK_QUEUE=fetcher.extract-external-data.queue
RABBITMQ_JOB_EVENTS_EXCHANGE=fetcher.job.events

# SEAWEEDFS CONFIGS
SEAWEEDFS_HOST=fetcher-seaweedfs-filer
SEAWEEDFS_FILER_PORT=8889
SEAWEEDFS_TTL=6M

# STORAGE PROVIDER
# Supported values: "seaweedfs" (default), "s3"
# When set to "s3", the OBJECT_STORAGE_* variables below are used.
# When set to "seaweedfs" (or empty), the SEAWEEDFS_* variables above are used.
STORAGE_PROVIDER=seaweedfs

# S3-COMPATIBLE OBJECT STORAGE (used when STORAGE_PROVIDER=s3)
# Works with AWS S3, MinIO, SeaweedFS S3 API, and other S3-compatible services.
# SSL is controlled by the URL scheme of OBJECT_STORAGE_ENDPOINT:
#   http://minio:9000  → no SSL (local/dev)
#   https://           → SSL (production / AWS S3 real)
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=external-data
OBJECT_STORAGE_KEY_PREFIX=
OBJECT_STORAGE_ACCESS_KEY_ID=your_access_key_here
OBJECT_STORAGE_SECRET_KEY=your_secret_key_here
OBJECT_STORAGE_USE_PATH_STYLE=false

# MONGO DB
#MONGO_URI=mongo+srv
MONGO_URI=mongodb
MONGO_HOST=fetcher-mongodb
MONGO_NAME=fetcher-db
MONGO_USER=plugin
MONGO_PASSWORD=CHANGE_ME_set_secure_password
MONGO_PORT=5709
MONGO_MAX_POOL_SIZE=1000

# LOG LEVEL
LOG_LEVEL=debug

# OPEN TELEMETRY
OTEL_RESOURCE_SERVICE_NAME=fetcher-worker
OTEL_LIBRARY_NAME=github.com/LerianStudio/fetcher
OTEL_RESOURCE_SERVICE_VERSION=${VERSION}
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=${ENV_NAME}
OTEL_EXPORTER_OTLP_ENDPOINT_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT=midaz-otel-lgtm:${OTEL_EXPORTER_OTLP_ENDPOINT_PORT}
ENABLE_TELEMETRY=false

# LICENSE
LICENSE_KEY=your-plugin-license-key
ORGANIZATION_IDS=your-organization-id1,your-organization-id2

# STORAGE ENCRYPTION KEYS
# Encrypt data at rest regardless of storage provider.
# Kept as SEAWEEDFS_* for backward compatibility.
CRYPTO_ENCRYPT_FILE_STORAGE=your_encrypt_secret_key_here
CRYPTO_HASH_SECRET_KEY_FILE_STORAGE=your_hash_secret_key_here

# CRM PLUGIN ENCRYPTION KEYS
CRYPTO_ENCRYPT_SECRET_KEY_PLUGIN_CRM=your_crm_encrypt_secret_key_here
CRYPTO_HASH_SECRET_KEY_PLUGIN_CRM=your_crm_hash_secret_key_here

# REDIS
REDIS_HOST=fetcher-valkey
REDIS_PORT=5707
REDIS_PASSWORD=CHANGE_ME_set_secure_password
REDIS_DB=0

# MULTI-TENANT
# Enable multi-tenant mode (default: false for backward compatibility)
MULTI_TENANT_ENABLED=false
# Tenant Manager service URL (required when MULTI_TENANT_ENABLED=true)
#MULTI_TENANT_URL=http://tenant-manager:8080
# Environment for cache key segmentation
#MULTI_TENANT_ENVIRONMENT=staging
# Soft limit for tenant connection pools (LRU eviction, default: 100 if unset)
#MULTI_TENANT_MAX_TENANT_POOLS=100
# Seconds before idle tenant connection is eviction-eligible
#MULTI_TENANT_IDLE_TIMEOUT_SEC=300
# Consecutive failures before circuit breaker opens
#MULTI_TENANT_CIRCUIT_BREAKER_THRESHOLD=5
# Seconds before circuit breaker resets (half-open)
#MULTI_TENANT_CIRCUIT_BREAKER_TIMEOUT_SEC=30
                "some_table": ["field1", "field2"]
            }
        }
    },
    "metadata": {
        "source": "rest_client_test",
        "testName": "ErrorMissingDatasource"
    }
}

###

### Create Fetcher Job - Non-existent Table (Job will fail during processing)
POST {{baseUrl}}/v1/fetcher
Content-Type: application/json
Authorization: Bearer {{token}}
X-Organization-Id: {{organizationId}}

{
    "dataRequest": {
        "mappedFields": {
            "postgres_test": {
                "this_table_does_not_exist": ["id", "name"]
            }
        }
    },
    "metadata": {
        "source": "rest_client_test",
        "testName": "ErrorNonExistentTable"
    }
}

